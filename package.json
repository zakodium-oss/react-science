{
  "name": "react-science",
  "version": "20.6.1",
  "description": "React components to build scientific applications UI",
  "type": "module",
  "exports": {
    "./ui": "./lib/components/index.js",
    "./styles/*.css": "./styles/*.css"
  },
  "files": [
    "lib",
    "src/components",
    "styles/preflight.css"
  ],
  "scripts": {
    "build": "npm run clean && npm run build-ts",
    "build-all": "npm run build-app && npm run build-storybook && mv storybook-static dist/stories",
    "build-app": "cross-env NO_MINIFY=true vite build",
    "build-storybook": "storybook build",
    "build-ts": "tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "clean": "rimraf lib",
    "createData": "npm run prepack && node scripts/createData",
    "dev": "echo Use npm run dev-app or npm run storybook && exit 1",
    "dev-app": "vite --open /pages/demo.html",
    "eslint": "eslint . --cache --max-warnings=45",
    "eslint-fix": "npm run eslint -- --fix",
    "playwright": "npm run playwright-ct -- --project chromium && npm run playwright-e2e -- --project chromium",
    "playwright-ct": "playwright test -c playwright-ct.config.mts",
    "playwright-e2e": "playwright test -c playwright-e2e.config.mts",
    "prepack": "npm run build",
    "prettier": "prettier --check .",
    "prettier-write": "prettier --write .",
    "serve": "vite preview",
    "storybook": "storybook dev -p 6006",
    "stylelint": "stylelint src stories styles",
    "stylelint-fix": "npm run stylelint -- --fix",
    "test": "npm run playwright && npm run test-only && npm run check-types && npm run stylelint && npm run eslint && npm run prettier",
    "test-only": "vitest run --coverage "
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zakodium-oss/react-science.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zakodium-oss/react-science/issues"
  },
  "homepage": "https://github.com/zakodium-oss/react-science#readme",
  "peerDependencies": {
    "@blueprintjs/core": "^6.16.0",
    "@blueprintjs/icons": "^6.11.0",
    "@blueprintjs/select": "^6.3.0",
    "fifo-logger": "^2.0.1",
    "react": "^18.3.1 || ^19.2.7",
    "react-dom": "^18.3.1 || ^19.2.7"
  },
  "dependencies": {
    "@emotion/styled": "^11.14.1",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@tanstack/react-form": "^1.33.2",
    "@tanstack/react-store": "^0.11.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.6",
    "@zakodium/pdnd-esm": "^1.1.0",
    "@zakodium/utils": "^0.4.1",
    "d3-scale-chromatic": "^3.1.0",
    "react-d3-utils": "^3.1.2",
    "react-dropzone": "^17.0.0",
    "react-full-screen": "^1.1.1",
    "react-icons": "^5.7.0",
    "react-inspector": "^9.0.0",
    "tinycolor2": "^1.6.0",
    "ts-pattern": "^5.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@blueprintjs/core": "6.16.0",
    "@blueprintjs/icons": "6.11.0",
    "@blueprintjs/select": "6.3.0",
    "@floating-ui/react": "^0.27.20",
    "@playwright/experimental-ct-react": "^1.61.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@tanstack/react-query": "^5.101.2",
    "@types/babel__core": "^7.20.5",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/node": "^24.13.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/tinycolor2": "^1.4.6",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@zakodium/tsconfig": "^1.0.5",
    "biologic-converter": "^1.0.0",
    "cheminfo-font": "^1.27.0",
    "cheminfo-types": "^1.15.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.5",
    "eslint-config-zakodium": "^20.1.0",
    "eslint-plugin-storybook": "^10.5.0",
    "fifo-logger": "2.0.1",
    "filelist-utils": "^1.11.3",
    "immer": "^11.1.11",
    "jcampconverter": "^12.5.2",
    "ml-gsd": "^14.2.1",
    "ml-peak-shape-generator": "^5.2.1",
    "ml-signal-processing": "^2.2.2",
    "ml-spectra-processing": "^14.29.2",
    "ms-spectrum": "^3.10.1",
    "netcdfjs": "^4.0.0",
    "postcss-styled-syntax": "^0.7.2",
    "prettier": "^3.9.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-error-boundary": "^6.1.2",
    "react-kbs": "^3.1.0",
    "react-ocl": "^8.7.2",
    "react-plot": "^3.1.2",
    "rimraf": "^6.1.3",
    "spc-parser": "^2.1.0",
    "storybook": "^10.5.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wdf-parser": "^1.0.0"
  },
  "volta": {
    "node": "24.18.0"
  }
}
